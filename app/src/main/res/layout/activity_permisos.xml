<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <!-- Barra superior con botones de acción -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/white">

        <Button
            android:id="@+id/btnNuevo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/permisos_nuevo"
            android:textSize="13sp"
            android:backgroundTint="@color/nuclear_blue"
            android:textColor="@color/white"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnHistorial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/permisos_historial"
            android:textSize="13sp"
            android:layout_marginStart="8dp"
            android:backgroundTint="@color/grey_done"
            android:textColor="@color/white"
            android:visibility="gone" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvOffline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:gravity="center"
        android:text="Sin conexion — mostrando datos guardados"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:background="@color/warning_orange"
        android:visibility="gone" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="48dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvVacio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/permisos_vacio"
        android:textSize="15sp"
        android:gravity="center"
        android:layout_marginTop="64dp"
        android:textColor="@color/grey_cancelled"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginTop="64dp"
        android:textColor="@color/danger_red"
        android:visibility="gone" />

    <ListView
        android:id="@+id/listViewPermisos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:padding="8dp"
        android:visibility="gone" />

</LinearLayout>
